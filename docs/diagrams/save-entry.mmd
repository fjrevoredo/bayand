%%{init: {"theme":"base","themeVariables":{
  "fontFamily":"Inter, system-ui, sans-serif",
  "primaryColor":"#E3F2FD",
  "primaryTextColor":"#0F172A",
  "primaryBorderColor":"#90CAF9",
  "lineColor":"#90A4AE"
}}}%%
flowchart TB

  classDef ui fill:#E0F2FE,stroke:#0284C7,stroke-width:2px,color:#111827;
  classDef backend fill:#DCFCE7,stroke:#16A34A,stroke-width:2px,color:#111827;
  classDef data fill:#FEF3C7,stroke:#D97706,stroke-width:2px,color:#111827;
  classDef decision fill:#FEF9C3,stroke:#CA8A04,stroke-width:2px,color:#111827;

  DATE["Selected date"]
  LOAD["get_records_for_date(date)"]
  PANEL["RecordPanel state<br/>current record, day list,<br/>debounced draft values"]
  EDIT["Edit symptoms, medications,<br/>vitals, sleep, wellbeing, notes"]
  HAVEID{"Record id<br/>already exists?"}
  CREATE["create_record(date)"]
  SAVE["save_record(id, payload)"]
  EMPTY{"Delete requested and<br/>payload is empty?"}
  DELETE["delete_record_if_empty(id, payload)"]
  ENC["Encrypt payload JSON<br/>with unlocked master key"]
  DB1["records table<br/>date plaintext<br/>payload encrypted"]
  DATES["get_all_record_dates()<br/>refresh calendar indicators"]

  DATE --> LOAD --> PANEL --> EDIT --> HAVEID
  HAVEID -- No --> CREATE --> SAVE
  HAVEID -- Yes --> SAVE
  SAVE --> EMPTY
  EMPTY -- Yes --> DELETE --> DATES
  EMPTY -- No --> ENC --> DB1 --> DATES

  class DATE,LOAD,PANEL,EDIT,DATES ui;
  class CREATE,SAVE,DELETE,ENC backend;
  class DB1 data;
  class HAVEID,EMPTY decision;
