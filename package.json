{
  "name": "bayand",
  "version": "0.0.1",
  "description": "A privacy-first local-only desktop health tracker",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "tauri": "tauri",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "pre-commit": "node scripts/pre-commit.js",
    "check": "node scripts/quick-check.js",
    "diagrams": "node scripts/render-diagrams.mjs",
    "diagrams:check": "node scripts/verify-diagrams.mjs",
    "test:e2e": "node scripts/run-e2e.js clean",
    "test:e2e:stateful": "node scripts/run-e2e.js stateful",
    "test:e2e:local": "node scripts/e2e-local.js"
  },
  "license": "MIT",
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tiptap/core": "^3.19.0",
    "@tiptap/extension-highlight": "^3.19.0",
    "@tiptap/extension-image": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-underline": "^3.19.0",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "lucide-solid": "^0.576.0",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@wdio/cli": "^9",
    "@wdio/local-runner": "^9",
    "@wdio/mocha-framework": "^9",
    "@wdio/spec-reporter": "^9",
    "@wdio/types": "^9",
    "@eslint/js": "^10.0.1",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@solidjs/testing-library": "^0.8.10",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@unocss/reset": "^66.6.0",
    "@unocss/vite": "^66.6.0",
    "@vitest/ui": "^4.0.18",
    "eslint": "^10.0.0",
    "eslint-plugin-solid": "^0.14.5",
    "happy-dom": "^20.6.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.55.0",
    "unocss": "^66.6.0",
    "vite": "^8.0.2",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.0.18",
    "webdriverio": "^9"
  }
}
